{
  "expo": {
    "name": "SleepTrack",
    "slug": "sleeptrack",
    "version": "1.0.0",
    "scheme": "sleeptrack",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon-converted.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.dynamite12.sleeptrack"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
